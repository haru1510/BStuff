def siteConfigParserCode = '''
def parseSiteConfiguration(String text) {
    def config = [SITES: [:]]
    def currentSite = null
    def currentSection = null
    text.eachLine { rawLine ->
        def line = rawLine.replaceAll(/#.*$/, '')
        if (!line.trim()) return
        def indent = line.takeWhile { it == ' ' }.size()
        def content = line.trim()
        if (indent == 0) {
            if (content == 'SITES:') return
        } else if (indent == 2 && content.endsWith(':')) {
            currentSite = content[0..-2]
            config.SITES[currentSite] = [:]
            currentSection = null
        } else if (currentSite != null && indent == 4 && content.endsWith(':')) {
            currentSection = content[0..-2]
            config.SITES[currentSite][currentSection] = (currentSection in ['LABS', 'AGENTS']) ? [] : [:]
        } else if (currentSite != null && currentSection != null && indent == 6) {
            if (content.startsWith('-')) {
                def item = content.substring(1).trim().replaceAll(/^'(.*)'$/, '\\$1')
                config.SITES[currentSite][currentSection] << item
            } else if (content.contains(':')) {
                def parts = content.split(':', 2)
                def key = parts[0].trim()
                def value = parts[1].trim()
                if (value.startsWith("'") && value.endsWith("'")) {
                    value = value[1..-2]
                }
                config.SITES[currentSite][currentSection][key] = value
            }
        }
    }
    return config
}
'''

evaluate(siteConfigParserCode)

def config = parseSiteConfiguration(new File(env.WORKSPACE + '/SiteConfiguration.yml').text)
def sites = config.SITES.keySet().sort().join('\n')
def defaultSite = config.SITES.keySet().iterator().next()

def siteConfigReactiveScriptPrefix = """${siteConfigParserCode}
    def cfg = parseSiteConfiguration(new File(env.WORKSPACE + '/SiteConfiguration.yml').text)
    def site = SITE ?: '${defaultSite}'
"""

properties([
    parameters([
        choice(name: 'SITE', choices: sites, description: 'Site'),
        activeChoiceReactiveReferenceParam(
            name: 'LAB_NAME',
            description: 'Lab name',
            choiceType: 'SINGLE_SELECT',
            referencedParameters: 'SITE',
            groovyScript: [
                sandbox: true,
                script: """${siteConfigReactiveScriptPrefix}return cfg.SITES[site].LABS ?: []"""
            ]
        ),
        activeChoiceReactiveReferenceParam(
            name: 'AGENT',
            description: 'Agent label',
            choiceType: 'SINGLE_SELECT',
            referencedParameters: 'SITE',
            groovyScript: [
                sandbox: true,
                script: """${siteConfigReactiveScriptPrefix}return cfg.SITES[site].AGENTS ?: []"""
            ]
        ),
        activeChoiceReactiveReferenceParam(
            name: 'HTTP_SERVER',
            description: 'HTTP server',
            choiceType: 'SINGLE_SELECT',
            referencedParameters: 'SITE',
            groovyScript: [
                sandbox: true,
                script: """${siteConfigReactiveScriptPrefix}return [ cfg.SITES[site].HTTP_SERVER ?: '' ]"""
            ]
        ),
    ])
])

pipeline {
    agent any
    stages {
        stage('Echo Parameters') {
            steps {
                sh '''
                    echo "SITE=${SITE}"
                    echo "AGENT=${AGENT}"
                    echo "LAB_NAME=${LAB_NAME}"
                    echo "HTTP_SERVER=${HTTP_SERVER}"
                    echo "instage=${instage}"
                '''
            }
        }
        stage('Run ROHOS-install') {
            steps {
                script {
                    build job: 'ROHOS-install', parameters: [
                        string(name: 'SITE', value: params.SITE),
                        string(name: 'LAB_NAME', value: params.LAB_NAME),
                        string(name: 'AGENT', value: params.AGENT),
                        string(name: 'HTTP_SERVER', value: params.HTTP_SERVER),
                    ], wait: true
                }
            }
        }
        stage('Run FW-upgrade') {
            steps {
                script {
                    build job: 'FW-upgrade', parameters: [
                        string(name: 'SITE', value: params.SITE),
                        string(name: 'LAB_NAME', value: params.LAB_NAME),
                        string(name: 'AGENT', value: params.AGENT),
                    ], wait: true
                }
            }
        }
    }

}